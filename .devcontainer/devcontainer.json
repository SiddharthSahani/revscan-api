{
  "name": "RevScan API",
  "build": {
    "dockerfile": "../docker/Dockerfile"
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "echo 'Container ready! Run: uvicorn main:app --host 0.0.0.0 --port 8000'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.flake8",
        "ms-python.autopep8"
      ]
    }
  },
  "remoteUser": "root"
}
